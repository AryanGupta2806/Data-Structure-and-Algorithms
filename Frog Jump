class Solution {
  public:
    int minCost(vector<int>& height) {
          return cost(height,height.size()-1);
    }
    int cost(vector<int>& arr,int i)
    {
        if(i==0)
        {
            return 0;
        }
        int lefttt=INT_MAX;
        int left=cost(arr,i-1)+abs(arr[i]-arr[i-1]);
        if(i>1)
         lefttt=cost(arr,i-2)+abs(arr[i]-arr[i-2]);
        return min(left,lefttt);
        
    }
};
