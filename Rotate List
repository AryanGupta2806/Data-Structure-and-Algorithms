class Solution {
public:
    ListNode* rotateRight(ListNode* head, int k) {
        int count=0;
     ListNode* abc=head;
     ListNode* dummy=head;
       if(head == NULL || head->next == NULL)
       return head;

     while(abc!=NULL)
     {
         count++;
         abc=abc->next;
     }

     int rot=k%count;
      if(rot == 0)
      return head;
     int point=count-rot;
     abc=head;

     for(int i=1;i<point;i++)
     {
     abc=abc->next;
     }

       ListNode* part2 = abc->next;
        abc->next = NULL;
       ListNode* temp = part2;

        while(temp->next != NULL)
        {
            temp = temp->next;
        }

        temp->next = head;
        head = part2;

    return head;
    }
    }
;
