
class Solution {
public:
    vector<int> count_NGE(vector<int> &arr, vector<int> &indices)
    {
        vector<int> fin;
        for(int i = 0; i < indices.size(); i++)
{
    stack<int> st;

    for (int j = indices[i] + 1; j < arr.size(); j++)
    {
        st.push(arr[j]);
    }

    int cnt = 0;

    while (!st.empty())
    {
        if (st.top() > arr[indices[i]])
            cnt++;
        st.pop();
    }

    fin.push_back(cnt);
}
return fin;
}
};
