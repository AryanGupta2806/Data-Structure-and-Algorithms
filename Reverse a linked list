class Solution {
  public:
    Node* reverseList(Node* head) 
    {
        Node* prev=NULL;
          Node* agla;
           Node* curr=head;
           while(curr!=NULL)
           {
               agla=curr->next;
               curr->next=prev;
               prev=curr;
               curr=agla;
               
           }
           return prev;
        
    }
}; 
