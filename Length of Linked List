/* Structure of linked list Node
class Node {
  public:
    int data;
    Node *next;

    Node(int x) {
        data = x;
        next = nullptr;
    }
};
*/
class Solution {
  public:
    int getCount(Node* head) {
     int count=0;
     Node* abc=head;
    
     
     while(abc!=NULL)
     {
         count++;
         abc=abc->next;
     }
     return count;
    }
};
