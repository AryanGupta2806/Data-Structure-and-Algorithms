class Solution {
  public:
    Node *insertAtPos(Node *head, int p, int x) {
        
        Node* abc = new Node(x);
        
        Node* temp = head;
        
       
        for(int i = 0; i < p; i++)
        {
            temp = temp->next;
        }
        
  
        abc->next = temp->next;
        abc->prev = temp;
        
        if(temp->next != NULL)
            temp->next->prev = abc;
        
        temp->next = abc;
        
        return head;
    }
};
