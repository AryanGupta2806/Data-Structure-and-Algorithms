#include <iostream>
#include <vector>
using namespace std;

int largest(vector<int>& arr) {
    int max = arr[0];

    //Traverse  from second and compare
    // every element with current max
    for (int i = 1; i < arr.size(); i++)
        if (arr[i] > max)
            max = arr[i];

    return max;
}

int main() {
    vector<int> arr = {20, 10, 20, 4, 100};
    cout << largest(arr);
    return 0;
}
